{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES6", "DOM"],
    "types": ["cypress", "node"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": false,
    //se usa el baseURL para que se sepa desde donde ubicar los paths
    "baseUrl": "./cypress",
    //rutas personalizadas de paths
    "paths": {
      "@action/*": ["e2e/action/*"],
      "@task/*": ["e2e/task/*"],
      "@ui/*": ["e2e/UI/*"],
      "@questions/*": ["e2e/question/*"],
      "@assertion/*": ["e2e/assertion/*"],
      "@fixtures/*": ["fixtures/*"]
    }
  },
  "include": [
    "cypress/**/*.ts",
    "cypress/**/*.js",
    "cypress/**/*.d.ts"
  ]
}